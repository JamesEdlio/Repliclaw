{
  "agents": {
    "edith": {
      "runtime": "kern",
      "workspaceTemplate": {
        "type": "git",
        "url": "https://github.com/JamesEdlio/edith-workspace.git",
        "branch": "replica-template"
      },
      "envFile": "./creds/edith.env",
      "model": "openrouter/anthropic/claude-opus-4.7",
      "provider": "openrouter"
    },
    "hello": {
      "runtime": "kern",
      "workspaceTemplate": {
        "type": "local",
        "path": "./templates/hello"
      },
      "envFile": "./creds/hello.env",
      "model": "openrouter/anthropic/claude-haiku-4.5",
      "provider": "openrouter"
    }
  }
}
