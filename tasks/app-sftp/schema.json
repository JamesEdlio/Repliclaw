{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "app-sftp data payload",
  "description": "Data payload for the app-sftp Forge-native task (v0.1.0).",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "ticket_key"],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "wrong_type",
        "already_sent",
        "needs_input",
        "declined",
        "error"
      ],
      "description": "High-level outcome of the task. Drives UI messaging on Forge."
    },
    "ticket_key": {
      "type": "string",
      "minLength": 1,
      "description": "Forge ticket key (INT-### or SS-###). Echo of the input."
    },
    "declined_reason": {
      "type": "string",
      "description": "Human-readable reason when status is wrong_type / declined."
    },
    "routing_suggestion": {
      "type": "string",
      "description": "If declined due to wrong_type, a hint about who should handle it instead."
    },
    "missing": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Field names that need human input when status is needs_input."
    },
    "note": {
      "type": "string",
      "description": "Free-form explanation accompanying a non-ok status."
    },
    "prior_run": {
      "type": ["object", "null"],
      "description": "Populated when status is already_sent. Extracted from the prior [app-sftp] setup-sent marker comment on the Forge ticket.",
      "additionalProperties": false,
      "properties": {
        "run_id": { "type": ["string", "null"] },
        "ts": { "type": ["string", "null"] },
        "skill_version": { "type": ["string", "null"] },
        "comment_id": { "type": ["string", "null"] },
        "author": { "type": ["string", "null"] }
      }
    },
    "filemage_user": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "user_id": { "type": ["integer", "null"] },
        "username": { "type": ["string", "null"] },
        "endpoint_name": { "type": ["string", "null"] },
        "provisioned_now": { "type": ["boolean", "null"] }
      }
    },
    "dashboard_ftp_account": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "account_id": { "type": ["integer", "null"] },
        "district_id": { "type": ["integer", "null"] },
        "district_name": { "type": ["string", "null"] },
        "enabled": { "type": ["boolean", "null"] },
        "created_now": { "type": ["boolean", "null"] },
        "existing": { "type": ["boolean", "null"] }
      }
    },
    "outreach": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "email_to": {
          "type": "array",
          "items": { "type": "string", "format": "email" }
        },
        "email_cc": {
          "type": "array",
          "items": { "type": "string", "format": "email" }
        },
        "email_subject": { "type": ["string", "null"] },
        "email_sent_at": { "type": ["string", "null"], "format": "date-time" },
        "op_item_id": { "type": ["string", "null"] },
        "op_share_url": { "type": ["string", "null"] },
        "op_share_expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "forge": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "comment_posted": { "type": "boolean" },
        "comment_id": { "type": ["string", "null"] },
        "status_transition": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {
            "from": { "type": "string" },
            "to": { "type": "string" }
          }
        }
      }
    },
    "skill_version": {
      "type": "string",
      "description": "Version of this skill that produced the envelope."
    },
    "dry_run": {
      "type": "boolean",
      "description": "True if the task was invoked with dry_run=true."
    },
    "triggered_by": {
      "type": ["string", "null"],
      "description": "Email of the human who dispatched this run (best-effort, may be null for system/cron triggers)."
    }
  }
}
